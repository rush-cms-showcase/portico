---
import { ClientRouter } from 'astro:transitions'
import '@/styles/app.css'
import Header from '@/components/layout/header.astro'
import Footer from '@/components/layout/footer.astro'
import WhatsAppButton from '@/components/ui/whatsapp-button.astro'

const SITE_URL = 'https://porticoreformas.com.br'

interface Props {
	title: string
	description: string
	image?: string
	type?: 'website' | 'article'
	schema?: string
}

const { 
	title, 
	description, 
	image = '/banner.webp', 
	type = 'website',
	schema
} = Astro.props

const canonical = new URL(Astro.url.pathname, Astro.site || SITE_URL).href
const finalImage = image.startsWith('http') ? image : new URL(image, Astro.site || SITE_URL).href

// Default schema if none provided
const defaultSchema = JSON.stringify({
	"@context": "https://schema.org",
	"@type": "LocalBusiness",
	"name": "Pórtico Reformas",
	"image": finalImage,
	"url": SITE_URL,
	"address": {
		"@type": "PostalAddress",
		"addressLocality": "Porto Alegre",
		"addressRegion": "RS",
		"addressCountry": "BR"
	}
})

const finalSchema = schema || defaultSchema
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="description" content={description} />
		<title>{title}</title>

		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonical} />
		<meta property="og:site_name" content="Pórtico Reformas" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={finalImage} />

		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonical} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={finalImage} />

		<link rel="canonical" href={canonical} />

		<!-- JSON-LD Schema -->
		<script type="application/ld+json" set:html={finalSchema} />

		<!-- Google Analytics -->
		{import.meta.env.GA_TAG && (
			<>
				<script async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.GA_TAG}`} is:inline></script>
				<script define:vars={{ gaTag: import.meta.env.GA_TAG }}>
					window.dataLayer = window.dataLayer || [];
					function gtag(){dataLayer.push(arguments);}
					gtag('js', new Date());
					gtag('config', gaTag);
				</script>
			</>
		)}

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<link rel="preload" as="image" href="/images/hero-bg.webp" fetchpriority="high" />

		<link
			href="https://fonts.googleapis.com/css2?family=Lexend+Deca:wght@400;600;700&family=Nunito+Sans:wght@400;600;700&display=swap"
			rel="stylesheet"
		/>

		<ClientRouter />
	</head>
	<body class="font-body text-charcoal antialiased">
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
		<WhatsAppButton />
		<script>
			import 'iconify-icon'
		</script>
	</body>
</html>
