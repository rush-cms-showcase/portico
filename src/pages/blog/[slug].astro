---
import BaseLayout from '@/layouts/base-layout.astro'
import CtaSection from '@/components/sections/cta-section.astro'
import { useTranslations } from '@/lib/i18n'
import { getCollection } from '@/lib/rush'

export async function getStaticPaths() {
  try {
    const res = await getCollection('blog', { per_page: 100 })
    return (res.data ?? []).map((p: any) => ({
      params: { slug: p.slug },
      props: { postData: p },
    }))
  } catch {
    return []
  }
}

const t = useTranslations('pt_BR')
const post: any = Astro.props.postData

function renderRichText(node: any): string {
  if (!node) return ''
  if (typeof node === 'string') return node
  if (Array.isArray(node)) return node.map(renderRichText).join('')
  switch (node.type) {
    case 'doc': return renderRichText(node.content)
    case 'paragraph': return `<p class="font-body text-lg text-charcoal leading-relaxed mb-5">${renderRichText(node.content)}</p>`
    case 'text': {
      let text = node.text || ''
      ;(node.marks || []).forEach((m: any) => {
        if (m.type === 'bold') text = `<strong class="font-bold text-navy">${text}</strong>`
        if (m.type === 'italic') text = `<em>${text}</em>`
        if (m.type === 'link') text = `<a href="${m.attrs.href}" class="text-gold-600 hover:underline" target="_blank" rel="noopener noreferrer">${text}</a>`
      })
      return text
    }
    case 'heading': {
      const l = node.attrs?.level || 2
      const s: Record<number, string> = { 1: 'text-4xl', 2: 'text-3xl', 3: 'text-2xl', 4: 'text-xl' }
      return `<h${l} class="${s[l] || 'text-lg'} font-heading font-bold text-navy mt-10 mb-4">${renderRichText(node.content)}</h${l}>`
    }
    case 'bulletList': return `<ul class="list-disc pl-6 mb-6 space-y-2 font-body text-charcoal">${renderRichText(node.content)}</ul>`
    case 'orderedList': return `<ol class="list-decimal pl-6 mb-6 space-y-2 font-body text-charcoal">${renderRichText(node.content)}</ol>`
    case 'listItem': return `<li class="leading-relaxed">${renderRichText(node.content)}</li>`
    case 'blockquote': return `<blockquote class="border-l-4 border-gold-600 pl-6 italic text-charcoal/80 my-8 font-body text-lg">${renderRichText(node.content)}</blockquote>`
    case 'customBlock':
      if (node.attrs?.id === 'youtube_embed') {
        const { url, caption } = node.attrs.config || {}
        const videoId = url?.match(/(?:v=|youtu\.be\/)([^&?]+)/)?.[1]
        if (!videoId) return ''
        return `<div class="my-8 rounded-2xl overflow-hidden aspect-video"><iframe src="https://www.youtube.com/embed/${videoId}" title="${caption || ''}" class="w-full h-full" frameborder="0" allowfullscreen></iframe></div>`
      }
      return ''
    case 'horizontalRule': return '<hr class="my-10 border-stone-200" />'
    default: return node.content ? renderRichText(node.content) : ''
  }
}

const content = renderRichText(post?.data?.content || post?.content || '')

function formatDate(dateStr: string) {
  if (!dateStr) return ''
  return new Date(dateStr).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })
}

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post?.title,
  "description": post?.excerpt || '',
  "image": post?.featured_image?.url || '',
  "datePublished": post?.published_at || '',
  "author": {
    "@type": "Organization",
    "name": "Pórtico Reformas"
  }
})
---

<BaseLayout
  title={`${post?.title || 'Post'} - ${t.site.title}`}
  description={post?.excerpt || ''}
  type="article"
  image={post?.featured_image?.url || undefined}
  schema={articleSchema}
>
  <article class="pt-40 pb-20 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
      <div class="mb-8">
        <a href="/blog" class="inline-flex items-center gap-2 font-body text-sm text-charcoal/50 hover:text-gold-600 transition-colors">
          <iconify-icon icon="mdi:arrow-left" />
          Voltar ao Blog
        </a>
      </div>

      {post?.published_at && (
        <time class="font-body text-xs text-charcoal/40 uppercase tracking-wide">
          {formatDate(post.published_at)}
        </time>
      )}

      <h1 class="font-heading text-4xl sm:text-5xl font-bold text-navy mt-3 mb-6 leading-tight">
        {post?.title}
      </h1>

      {post?.excerpt && (
        <p class="font-body text-xl text-charcoal/70 leading-relaxed border-l-4 border-gold-600 pl-6 mb-8">
          {post.excerpt}
        </p>
      )}

      {post?.featured_image?.url && (
        <div class="aspect-video overflow-hidden rounded-2xl mb-12 bg-stone-100">
          <img
            src={post.featured_image.url}
            alt={post.featured_image.alt || post.title}
            class="w-full h-full object-cover"
          />
        </div>
      )}

      {content && (
        <div class="prose prose-lg max-w-none" set:html={content} />
      )}
    </div>
  </article>

  <CtaSection
    title="Pronto para transformar seu espaço?"
    description="Entre em contato e vamos planejar a sua reforma"
    variant="dark"
  />
</BaseLayout>
