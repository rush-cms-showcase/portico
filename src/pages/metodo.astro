---
import BaseLayout from '@/layouts/base-layout.astro'
import PageHeader from '@/components/sections/page-header.astro'
import CtaSection from '@/components/sections/cta-section.astro'
import { useTranslations } from '@/lib/i18n'
import { getEntryBySlug } from '@/lib/rush'
import { methods as staticMethods } from '@/lib/data/methods'

const t = useTranslations('pt_BR')

interface MetodoCard {
  abreviation: string
  title: string
  subtitle: string
  text: string
  tags: string
}

function parseTagsToFeatures(tags: string): string[] {
  return tags.split(',').map((t: string) => t.trim()).filter(Boolean)
}

let cards: MetodoCard[] = []
let useFallback = false

try {
  const res = await getEntryBySlug('pages', 'metodologia')
  const entry = (res as any).data ?? res
  const docContent = entry.data?.content?.content ?? []
  cards = docContent
    .filter((node: any) => node.type === 'customBlock' && node.attrs?.id === 'custom_metodo')
    .map((node: any) => node.attrs.config as MetodoCard)
  if (cards.length === 0) useFallback = true
} catch {
  useFallback = true
}
---

<BaseLayout
  title={`Método Pórtico 4P - ${t.site.title}`}
  description="Conheça o Método Pórtico 4P: Planejamento Cirúrgico, Previsibilidade Total, Proteção Contratual e Prestação de Contas. Inteligência aplicada à construção."
>
  <PageHeader
    badge="Metodologia Exclusiva"
    title="Método Pórtico 4P™"
    description="O único sistema de reforma que garante prazo, preço e qualidade em contrato."
  />

  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <div class="space-y-8">
        {useFallback ? (
          staticMethods.map((method) => (
            <div class="group relative">
              <div class="relative bg-stone-50 border-l-4 border-gold-600 p-8 lg:p-10 hover:border-gold-500 hover:shadow-lg transition-all duration-300">
                <div class="flex items-start gap-6">
                  <div class="shrink-0">
                    <div class="relative w-16 h-16">
                      <div class="absolute inset-0 bg-gold-600/10 transform rotate-45" />
                      <div class="absolute inset-0 flex items-center justify-center">
                        <span class="font-heading text-2xl font-black text-gold-600 relative z-10">
                          {method.letter}{method.number}
                        </span>
                      </div>
                    </div>
                  </div>
                  <div class="flex-1 min-w-0">
                    <h2 class="font-heading text-2xl lg:text-3xl font-bold text-navy mb-1 group-hover:text-gold-600 transition-colors">
                      {method.title}
                    </h2>
                    <p class="font-body text-sm text-gold-600 font-semibold mb-4 uppercase tracking-wide">
                      {method.subtitle}
                    </p>
                    <p class="font-body text-base text-charcoal leading-relaxed mb-6">
                      {method.description}
                    </p>
                    <div class="flex flex-wrap gap-2">
                      {method.features.map((f) => (
                        <span class="inline-flex items-center gap-1.5 bg-navy-900/5 border border-navy-900/10 px-3 py-1 rounded-sm text-xs text-charcoal font-medium">
                          <iconify-icon icon="mdi:check" class="text-gold-600" />
                          {f}
                        </span>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))
        ) : (
          cards.map((card) => (
            <div class="group relative">
              <div class="relative bg-stone-50 border-l-4 border-gold-600 p-8 lg:p-10 hover:border-gold-500 hover:shadow-lg transition-all duration-300">
                <div class="flex items-start gap-6">
                  <div class="shrink-0">
                    <div class="relative w-16 h-16">
                      <div class="absolute inset-0 bg-gold-600/10 transform rotate-45" />
                      <div class="absolute inset-0 flex items-center justify-center">
                        <span class="font-heading text-2xl font-black text-gold-600 relative z-10">
                          {card.abreviation}
                        </span>
                      </div>
                    </div>
                  </div>
                  <div class="flex-1 min-w-0">
                    <h2 class="font-heading text-2xl lg:text-3xl font-bold text-navy mb-1 group-hover:text-gold-600 transition-colors">
                      {card.title}
                    </h2>
                    <p class="font-body text-sm text-gold-600 font-semibold mb-4 uppercase tracking-wide">
                      {card.subtitle}
                    </p>
                    <p class="font-body text-base text-charcoal leading-relaxed mb-6">
                      {card.text}
                    </p>
                    <div class="flex flex-wrap gap-2">
                      {parseTagsToFeatures(card.tags).map((f) => (
                        <span class="inline-flex items-center gap-1.5 bg-navy-900/5 border border-navy-900/10 px-3 py-1 rounded-sm text-xs text-charcoal font-medium">
                          <iconify-icon icon="mdi:check" class="text-gold-600" />
                          {f}
                        </span>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))
        )}
      </div>

      <div class="relative mt-16 text-center py-12 px-8 border border-stone-200 rounded-2xl">
        <div class="flex items-center justify-center gap-4 mb-6">
          <div class="h-px w-16 bg-gold-600"></div>
          <iconify-icon icon="mdi:seal-variant" class="text-gold-600 text-3xl"></iconify-icon>
          <div class="h-px w-16 bg-gold-600"></div>
        </div>
        <p class="font-heading text-2xl lg:text-3xl text-navy font-light italic leading-relaxed">
          "Não fazemos reforma.<br />
          Fazemos <span class="font-bold not-italic text-gold-600">transformação inteligente</span> de espaços."
        </p>
      </div>
    </div>
  </section>

  <CtaSection
    title="Pronto para aplicar o Método 4P no seu projeto?"
    description="Vamos começar com um diagnóstico funcional gratuito"
    variant="dark"
  />
</BaseLayout>
