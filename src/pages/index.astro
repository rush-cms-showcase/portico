---
import BaseLayout from '@/layouts/base-layout.astro'
import HeroSection from '@/components/sections/hero-section.astro'
import ProjectShowcaseSection from '@/components/sections/project-showcase-section.astro'
import ReasonSection from '@/components/sections/reason-section.astro'
import JulioFactorSection from '@/components/sections/julio-factor-section.astro'
import Method4PSection from '@/components/sections/method-4p-section.astro'
import ServicesSection from '@/components/sections/services-section.astro'
import FAQSection from '@/components/sections/faq-section.astro'
import ContactSection from '@/components/sections/contact-section.astro'
import { useTranslations } from '@/lib/i18n'

const t = useTranslations('pt_BR')
---

<BaseLayout
  title="Pórtico Reformas - Sua reforma em Porto Alegre e região com prazo e orçamento garantidos"
  description="Antes de reformar, a gente entende como você vive. Reforma residencial em Porto Alegre e região com planejamento inteligente, prazo garantido e orçamento fixo em contrato."
>
  <HeroSection />
  <ProjectShowcaseSection />
  <ReasonSection />
  <section class="py-20 bg-stone-50">
    <div class="container max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <JulioFactorSection />
    </div>
  </section>
  <Method4PSection />
  <ServicesSection />
  <FAQSection />

  <section id="contato" class="py-20 bg-white">
    <div class="container mx-auto px-4 max-w-2xl">
      <h2 class="font-heading text-3xl font-semibold text-navy text-center mb-2">
        {t.contact.title}
      </h2>
      <p class="font-body text-center text-charcoal/60 mb-8">Escolha como prefere falar com a gente</p>
      <ContactSection />
    </div>
  </section>
</BaseLayout>
