---
import { useTranslations } from '@/lib/i18n'
import { getNav } from '@/lib/rush'
import { mapMenuItem } from '@/lib/nav'
import { rushConfig } from '../../../rush.config'

const t = useTranslations('pt_BR')
const navId = rushConfig.locales.pt_BR.navs?.main ?? ''

const staticLinks = [
  { label: t.nav.home, href: '/' },
  { label: t.nav.services, href: '/servicos' },
  { label: t.nav.about, href: '/sobre-nos' },
  { label: t.nav.method, href: '/sobre-nos' },
  { label: t.nav.contact, href: '/contato' },
]

let navLinks = staticLinks
try {
  const res = await getNav(navId)
  const items = res.data?.items ?? []
  if (items.length > 0) {
    navLinks = items.map((item: any) => {
      const mapped = mapMenuItem(item)
      return { label: mapped.title, href: mapped.url }
    })
  }
} catch {
  navLinks = staticLinks
}
---

<header class="fixed top-6 left-1/2 -translate-x-1/2 z-50 w-[95%] max-w-7xl">
  <div class="relative">
    <div
      class="absolute inset-0 bg-linear-to-r from-white/10 via-white/5 to-white/10 rounded-lg blur-xl"
    >
    </div>

    <div
      class="relative bg-white/20 rounded-lg p-4 backdrop-blur-2xl backdrop-saturate-200 border border-orange-200/30 shadow-2xl shadow-orange-300/25 transition-all duration-500 hover:shadow-3xl hover:border-white/40"
    >
      <div class="flex items-center justify-between">
        <a href="/" class="flex items-center group absolute -top-2 left-2">
          <div class="p-1 w-24 h-24">
            <img
              src="/portico-logo.svg"
              alt="Pórtico - Logo"
              class="w-full h-full object-contain"
            />
          </div>
        </a>

        <img
          src="/portico-logo-letter.svg"
          alt="Pórtico Reformas"
          class="h-6 ml-22 w-auto transition-transform duration-300 group-hover:scale-105"
        />

        <div class="flex items-center justify-center gap-4">
          <nav class="hidden md:flex items-center gap-1">
            {
              navLinks.map((link) => (
                <a
                  href={link.href}
                  class="relative px-5 py-2.5 font-body text-sm font-semibold text-navy-900 hover:text-navy-900 transition-all duration-300 rounded-lg hover:bg-white/40 group"
                >
                  <span class="relative z-10">{link.label}</span>
                  <div class="absolute inset-0 bg-linear-to-br from-white/0 to-white/30 rounded-md opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
                </a>
              ))
            }
          </nav>

          <div class="hidden md:flex items-center">
            <a
              href="/contato"
              class="relative px-6 py-3 font-body font-bold text-sm text-navy-900 rounded-md overflow-hidden group transition-colors"
            >
              <div class="absolute inset-0 bg-linear-to-br from-[#d4af37] via-[#f4d03f] to-[#c5a028]"></div>
              <span class="relative z-10">{t.buttons.requestQuote}</span>
            </a>
          </div>

          <button
            id="mobile-menu-button"
            class="md:hidden inline-flex items-center justify-center p-2.5 rounded-lg text-navy-900/80 hover:text-navy-900 hover:bg-white/40 focus:outline-none transition-all duration-300"
            aria-label="Menu"
          >
            <iconify-icon icon="mdi:menu" class="text-2xl"></iconify-icon>
          </button>
        </div>
      </div>
    </div>

    <div
      id="mobile-menu"
      class="hidden md:hidden mt-4 bg-white/20 backdrop-blur-2xl backdrop-saturate-200 border border-white/30 rounded-lg shadow-2xl shadow-navy/5 overflow-hidden"
    >
      <div class="px-4 py-4 space-y-1">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="block font-body text-sm font-medium text-navy-900/80 hover:text-navy-900 hover:bg-white/40 px-4 py-3 rounded-lg transition-all duration-300"
            >
              {link.label}
            </a>
          ))
        }
        <a
          href="/contato"
          class="block mt-3 px-6 py-3 font-body font-bold text-sm text-navy-900 text-center rounded-lg bg-linear-to-br from-[#d4af37] via-[#f4d03f] to-[#c5a028] shadow-lg transition-colors"
        >
          {t.buttons.requestQuote}
        </a>
      </div>
    </div>
  </div>

  <script src="@/scripts/mobile-menu.ts"></script>
</header>
