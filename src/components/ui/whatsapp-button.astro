---
const phone = import.meta.env.PUBLIC_WHATSAPP
const message = encodeURIComponent('Olá! Gostaria de agendar um diagnóstico gratuito.')
const href = `https://wa.me/${phone}?text=${message}`
---

{phone && (
	<a
		href={href}
		target="_blank"
		rel="noopener noreferrer"
		aria-label="Fale conosco pelo WhatsApp"
		class="fixed bottom-6 right-6 z-50 flex items-center justify-center w-14 h-14 rounded-full bg-[#25D366] shadow-lg shadow-black/20 hover:scale-110 hover:shadow-xl hover:shadow-[#25D366]/30 transition-all duration-300 group"
	>
		<iconify-icon icon="mdi:whatsapp" class="text-3xl text-white" />

		<span class="absolute right-16 bg-white text-charcoal font-body text-sm font-semibold px-3 py-1.5 rounded-lg shadow-md whitespace-nowrap opacity-0 group-hover:opacity-100 translate-x-2 group-hover:translate-x-0 transition-all duration-200 pointer-events-none">
			Fale pelo WhatsApp
		</span>
	</a>
)}
