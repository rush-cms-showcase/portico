---
const whatsapp = import.meta.env.PUBLIC_WHATSAPP
const instagram = import.meta.env.PUBLIC_INSTAGRAM
const facebook = import.meta.env.PUBLIC_FACEBOOK
const email = import.meta.env.PUBLIC_EMAIL

const waMessage = encodeURIComponent('Olá! Gostaria de agendar um diagnóstico gratuito.')

const channels = [
	whatsapp && {
		icon: 'mdi:whatsapp',
		label: 'WhatsApp',
		value: `+${whatsapp.replace(/\D/g, '').replace(/^55(\d{2})(\d{5})(\d{4})$/, '($1) $2-$3')}`,
		href: `https://wa.me/${whatsapp}?text=${waMessage}`,
		color: 'text-[#25D366]',
		bg: 'hover:bg-[#25D366]/10',
	},
	instagram && {
		icon: 'mdi:instagram',
		label: 'Instagram',
		value: '@porticoreformas',
		href: instagram,
		color: 'text-[#E1306C]',
		bg: 'hover:bg-[#E1306C]/10',
	},
	facebook && {
		icon: 'mdi:facebook',
		label: 'Facebook',
		value: '/porticoreformas',
		href: facebook,
		color: 'text-[#1877F2]',
		bg: 'hover:bg-[#1877F2]/10',
	},
	email && {
		icon: 'mdi:email-outline',
		label: 'E-mail',
		value: email,
		href: `mailto:${email}`,
		color: 'text-gold-600',
		bg: 'hover:bg-gold-600/10',
	},
].filter(Boolean)
---

<div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
	{channels.map((ch) => (
		<a
			href={ch.href}
			target="_blank"
			rel="noopener noreferrer"
			class={`flex flex-col items-center gap-2 p-4 rounded-xl border border-stone-200 transition-all duration-200 group ${ch.bg}`}
		>
			<iconify-icon icon={ch.icon} class={`text-3xl ${ch.color}`} />
			<span class="font-body text-xs font-semibold text-charcoal">{ch.label}</span>
			<span class="font-body text-xs text-charcoal/60 truncate max-w-full">{ch.value}</span>
		</a>
	))}
</div>
