---
interface FormField {
  type: string
  data: {
    config: {
      name: string
      label: string
      type?: string
      placeholder?: string
      default_value?: string
      hint?: string
    }
    validation?: {
      is_required?: boolean
      minlength?: number
      maxlength?: number
    }
  }
}

interface FormSchema {
  id: number
  name: string
  key: string
  description?: string
  fields: FormField[]
}

interface Props {
  form: FormSchema
}

const { form } = Astro.props
---

<div id="dynamic-form-container">
  <div id="form-success" class="hidden bg-green-50 border border-green-200 p-6 rounded-xl text-green-800 text-center">
    <iconify-icon icon="mdi:check-circle-outline" class="text-4xl text-green-500 mb-2" />
    <h3 class="font-heading text-xl font-semibold mb-1">Mensagem enviada!</h3>
    <p class="font-body text-sm">Entraremos em contato em breve.</p>
    <button id="btn-reset" class="mt-4 text-sm font-body underline text-green-700 hover:text-green-900">
      Enviar outra mensagem
    </button>
  </div>

  <div id="form-error" class="hidden bg-red-50 border border-red-200 p-4 rounded-xl text-red-700 font-body text-sm mb-4"></div>

  <form id="rush-dynamic-form" class="space-y-5" data-form-key={form.key} novalidate>
    <!-- Honeypot Field -->
    <div class="hidden" aria-hidden="true">
      <label for="website_url">Não preencha este campo se for humano</label>
      <input type="text" id="website_url" name="website_url" tabindex="-1" autocomplete="off" />
    </div>
    
    <!-- Renderizing real fields -->
    {form.fields.map((field) => {
      const { config, validation } = field.data
      const isRequired = validation?.is_required
      const fieldType = field.type === 'textarea' ? 'textarea' : (
        config.type === 'telephone' ? 'tel' : (config.type || 'text')
      )
      const inputClass = 'w-full px-4 py-3 border border-stone-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-navy focus:border-transparent font-body text-charcoal bg-white transition-shadow'

      return (
        <div class="space-y-1.5">
          <label for={config.name} class="block font-body text-sm font-semibold text-charcoal">
            {config.label}{isRequired && <span class="text-red-500 ml-1">*</span>}
          </label>
          {fieldType === 'textarea' ? (
            <textarea
              id={config.name}
              name={config.name}
              required={isRequired}
              placeholder={config.placeholder ?? undefined}
              rows={5}
              minlength={validation?.minlength ?? undefined}
              maxlength={validation?.maxlength ?? undefined}
              class={`${inputClass} resize-none`}
            />
          ) : (
            <input
              type={fieldType as any}
              id={config.name}
              name={config.name}
              required={isRequired}
              placeholder={config.placeholder ?? undefined}
              minlength={validation?.minlength ?? undefined}
              maxlength={validation?.maxlength ?? undefined}
              value={config.default_value || ''}
              class={inputClass}
            />
          )}
          {config.hint && <p class="text-xs text-charcoal/50 font-body">{config.hint}</p>}
        </div>
      )
    })}

    <div class="pt-2">
      <button
        type="submit"
        id="btn-dynamic-submit"
        class="w-full bg-navy-900 hover:bg-gold-600 transition-colors duration-300 text-white font-body font-bold text-base px-8 py-4 rounded-lg shadow-lg disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2"
      >
        <span id="btn-dynamic-text">Enviar Mensagem</span>
        <iconify-icon id="btn-dynamic-spinner" icon="mdi:loading" class="hidden text-xl animate-spin" />
      </button>
    </div>
  </form>
</div>

<script define:vars={{ RUSH_API_URL: import.meta.env.RUSH_API_URL, RUSH_SLUG: import.meta.env.RUSH_SLUG, RUSH_API_TOKEN: import.meta.env.RUSH_API_TOKEN }}>
  const form = document.getElementById('rush-dynamic-form')
  const successDiv = document.getElementById('form-success')
  const errorDiv = document.getElementById('form-error')
  const btnSubmit = document.getElementById('btn-dynamic-submit')
  const btnText = document.getElementById('btn-dynamic-text')
  const btnSpinner = document.getElementById('btn-dynamic-spinner')
  const btnReset = document.getElementById('btn-reset')
  
  // Track form initialization time for anti-bot speed check
  const initTime = Date.now()

  const validateEmail = (email) => {
    return String(email)
      .toLowerCase()
      .match(
        /^(([^<>()[\]\\.,;:\s@"]+(\.[^<>()[\]\\.,;:\s@"]+)*)|.(".+"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/
      );
  };

  const validatePhone = (phone) => {
    const cleaned = phone.replace(/\D/g, '');
    return cleaned.length >= 10 && cleaned.length <= 11;
  }

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      
      const formData = new FormData(form)
      
      // 1. Anti-bot: Honeypot check
      if (formData.get('website_url')) {
        // Silently succeed for bots
        form.reset()
        form.classList.add('hidden')
        successDiv?.classList.remove('hidden')
        return
      }
      
      // 2. Anti-bot: Speed check (humans take > 3s to read and fill)
      if (Date.now() - initTime < 3000) {
        if (errorDiv) {
          errorDiv.textContent = 'Ação suspeita detectada (muito rápido). Por favor, verifique os campos e tente novamente.'
          errorDiv.classList.remove('hidden')
        }
        return
      }

      // 3. Advanced Client Validation
      const inputs = form.querySelectorAll('input, textarea')
      let isValid = true
      
      // Clear all previous errors visually
      inputs.forEach(input => {
        input.classList.remove('border-red-500', 'bg-red-50/50')
        const existingHint = input.parentElement.querySelector('.text-red-500.text-xs.mt-1')
        if (existingHint) existingHint.remove()
      })

      const showError = (input, message) => {
        isValid = false
        input.classList.add('border-red-500', 'bg-red-50/50')
        const err = document.createElement('p')
        err.className = 'text-red-500 text-xs mt-1 font-body font-medium'
        err.innerText = message
        input.parentElement.appendChild(err)
      }

      inputs.forEach(input => {
        const val = input.value.trim()
        
        // Required check
        if (input.hasAttribute('required') && !val) {
          showError(input, 'Este campo é obrigatório.')
        } 
        // Email type validation
        else if (input.type === 'email' && val && !validateEmail(val)) {
          showError(input, 'Por favor, insira um e-mail válido.')
        }
        // Phone/Tel type validation
        else if (input.type === 'tel' && val && !validatePhone(val)) {
          showError(input, 'Insira um telefone válido com DDD (mín. 10 dígitos).')
        }
        // MinLength check
        else if (input.minLength && input.minLength > 0 && val && val.length < input.minLength) {
          showError(input, `Mínimo de ${input.minLength} caracteres.`)
        }
      })

      if (!isValid) {
        if (errorDiv) {
          errorDiv.textContent = 'Por favor, corrija os erros nos campos antes de enviar.'
          errorDiv.classList.remove('hidden')
        }
        return
      }

      errorDiv?.classList.add('hidden')
      if (btnSubmit) btnSubmit.disabled = true
      btnText?.classList.add('hidden')
      btnSpinner?.classList.remove('hidden')

      // Remove honeypot from actual payload
      formData.delete('website_url')
      
      const data = {}
      formData.forEach((v, k) => { data[k] = String(v) })
      const formKey = form.dataset.formKey

      try {
        const res = await fetch(`${RUSH_API_URL}/${RUSH_SLUG}/forms/${formKey}/submit`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${RUSH_API_TOKEN}`,
            'Accept': 'application/json',
          },
          body: JSON.stringify({ data }),
        })
        if (!res.ok) throw new Error('Falha no envio da API')
        
        form.classList.add('hidden')
        successDiv?.classList.remove('hidden')
        form.reset()
      } catch (err) {
        if (errorDiv) {
          errorDiv.textContent = 'Ocorreu um erro ao enviar sua mensagem. Nossa equipe já foi notificada. Por favor, contate-nos pelo WhatsApp direto no rodapé.'
          errorDiv.classList.remove('hidden')
        }
      } finally {
        if (btnSubmit) btnSubmit.disabled = false
        btnText?.classList.remove('hidden')
        btnSpinner?.classList.add('hidden')
      }
    })

    btnReset?.addEventListener('click', () => {
      successDiv?.classList.add('hidden')
      form.classList.remove('hidden')
    })
  }
</script>
