---
interface Props {
	badge: string
	title: string
	description?: string
}

const { badge, title, description } = Astro.props
---

<div class="max-w-3xl mb-12">
	<div class="inline-flex items-center gap-3 mb-4">
		<div class="w-1 h-6 bg-gold-600"></div>
		<span class="font-body text-sm text-gold-600 font-semibold tracking-widest uppercase">
			{badge}
		</span>
	</div>
	<h2 class="font-heading text-3xl sm:text-4xl font-bold text-navy-900 mb-4">
		{title}
	</h2>
	{description && (
		<p class="font-body text-lg text-navy-700">
			{description}
		</p>
	)}
</div>
