---
import { Image } from 'astro:assets'

interface Props {
	title?: string,
	text?: string[],
	quote?: {
		text: string,
		author: string,
	},
	image?: {
		src: string,
		alt: string,
	},
	features?: {
		icon: string,
		description: string,
	}[],
}

const {
	title = 'O Fator Júlio',
	text = [
		'Júlio não é apenas um executor. Ele é o cérebro da operação - o tradutor entre o seu sonho e a realidade do projeto.',
		'Com mais de 20 anos de experiência em reformas residenciais, Júlio antecipa problemas funcionais antes do primeiro martelo. Ele coordena uma equipe técnica especializada para garantir que cada detalhe seja perfeito.',
		'Ele não vende apenas uma reforma. Ele vende tranquilidade, prazo garantido e um resultado que realmente melhora a sua vida.'
	],
	quote = {
		text: 'Se a reforma não melhora a sua rotina, é só desperdício.',
		author: 'Júlio, Fundador',
	},
	image = {
		src: '/images/team/julio.png',
		alt: 'Júlio - Fundador e Estrategista da Pórtico Reformas',
	},
	features = [
		{
			icon: 'mdi:lightbulb-on',
			description: 'Diagnóstico Funcional',
		},
		{
			icon: 'mdi:account-group',
			description: 'Equipe Especializada',
		},
	],
} = Astro.props
---

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start">
	<Image
		src={image.src}
		alt={image.alt}
		class="w-full rounded-lg shadow-xl"
		loading="lazy"
		width={512}
		height={512}
		decoding="async"
	/>

	<div class="space-y-6">
		{text && text.map((text) => (
			<p class="font-body text-lg lg:text-xl text-charcoal leading-relaxed">
				{text}
			</p>
		))}

		{quote && (
			<div class="border-l-4 border-gold-600 px-6">
				<p class="font-body text-lg text-navy-800 italic">
					{quote.text}
				</p>
				<p class="font-body font-bold text-sm text-navy-900 mt-2">
				— {quote.author}
				</p>
			</div>
		)}

		{features && (
			<div class="grid grid-cols-2 gap-4 pt-4 border-t border-stone-200">
				{features.map((feature) => (
					<div class="text-center p-4 rounded-lg">
						<iconify-icon
							icon={feature.icon}
							class="text-3xl text-gold-500 mb-2"
						/>
						<p class="font-body font-semibold text-navy">
							{feature.description}
						</p>
					</div>
				))}
			</div>		
		)}
	</div>
</div>
