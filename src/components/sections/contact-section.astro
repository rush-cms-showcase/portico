---
import ContactChannels from '@/components/ui/contact-channels.astro'
import DynamicForm from '@/components/ui/dynamic-form.astro'
import { getForm } from '@/lib/rush'
import { rushConfig } from '../../../rush.config'

const formKey = String(rushConfig.locales.pt_BR.forms?.contact ?? '')
let formSchema = null

try {
  const res = await getForm(formKey)
  formSchema = res.data
} catch {
  formSchema = null
}
---

<ContactChannels />

<div class="flex items-center gap-4 my-8">
  <div class="flex-1 h-px bg-stone-200"></div>
  <span class="font-body text-xs text-charcoal/40 whitespace-nowrap">
    ou se preferir, fale pelo formulário abaixo
  </span>
  <div class="flex-1 h-px bg-stone-200"></div>
</div>

{formSchema ? (
  <DynamicForm form={formSchema} />
) : (
  <p class="font-body text-sm text-charcoal/50 text-center py-4">
    Formulário temporariamente indisponível. Use um dos canais acima.
  </p>
)}
