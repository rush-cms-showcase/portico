---
interface Props {
	badge?: string
	title: string
	description?: string
	highlights?: string[]
}

const { badge, title, description, highlights } = Astro.props
---

<section class="relative py-32 sm:py-40 bg-navy-900 text-white overflow-hidden">
	<div class="absolute inset-0 pointer-events-none">
		<div class="absolute top-0 left-0 w-96 h-96 bg-gold-600/10 rounded-full blur-3xl"></div>
		<div class="absolute bottom-0 right-0 w-96 h-96 bg-gold-600/10 rounded-full blur-3xl"></div>
	</div>

	<div class="container relative mx-auto px-4 sm:px-6 lg:px-8 text-center">
		{badge && (
			<div class="inline-flex items-center gap-3 bg-gold-600/10 border border-gold-600/20 px-4 py-2 rounded-sm mb-6">
				<div class="w-1 h-6 bg-gold-600"></div>
				<span class="font-body text-sm text-gold-500 font-semibold tracking-widest uppercase">
					{badge}
				</span>
			</div>
		)}

		<h1 class="font-heading text-5xl sm:text-6xl lg:text-7xl font-bold text-white mb-6">
			{title}
		</h1>

		{description && (
			<p class="font-body text-xl text-navy-100 max-w-3xl mx-auto leading-relaxed" class:list={[highlights ? 'mb-8' : '']}>
				{description}
			</p>
		)}

		{highlights && (
			<div class="flex flex-col sm:flex-row items-center justify-center gap-3 mt-8">
				{highlights.map((item) => (
					<div class="flex items-center gap-2 text-navy-200">
						<div class="w-1.5 h-1.5 bg-gold-600 rounded-full shrink-0"></div>
						<span class="font-body text-sm">{item}</span>
					</div>
				))}
			</div>
		)}
	</div>
</section>
