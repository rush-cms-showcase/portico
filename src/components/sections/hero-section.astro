---
import Button from '../atoms/button.astro'
import Heading from '../atoms/heading.astro'

interface Props {
  headline?: string
  subheadline?: string
}

const {
  headline = 'Transformamos espaços. Criamos legados.',
  subheadline = 'Reformas residenciais de alto padrão em Porto Alegre com design autoral e execução impecável',
} = Astro.props

const handleCTAClick = () => {
  document.getElementById('contato')?.scrollIntoView({ behavior: 'smooth' })
}
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <div class="absolute inset-0 z-0">
    <img
      src="/images/hero-bg.webp"
      alt="Reforma moderna e profissional"
      class="w-full h-full object-cover aspect-video"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-navy-900/90 via-navy-800/80 to-navy-900/40"></div>
  </div>

  <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
    <Heading level={1} class="text-white mb-6 leading-tight max-w-5xl mx-auto animate-fade-in-up">
      {headline}
    </Heading>

    <p class="font-body text-lg sm:text-xl lg:text-2xl text-navy-100 mb-10 max-w-3xl mx-auto animate-fade-in-up delay-100">
      {subheadline}
    </p>

    <div class="animate-fade-in-up delay-200">
      <Button href="#contato" variant="primary" size="md">
        Falar com um Especialista Agora
      </Button>
    </div>
  </div>

  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10 animate-bounce">
    <a href="#razoes" class="block text-white/50 hover:text-white transition-colors p-2">
      <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
      </svg>
    </a>
  </div>
</section>

<script>
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      e.preventDefault()
      const targetId = anchor.getAttribute('href')?.substring(1)
      if (targetId) {
        const target = document.getElementById(targetId)
        target?.scrollIntoView({ behavior: 'smooth' })
      }
    })
  })
</script>
