---
interface Props {
  headline?: string
  subheadline?: string
}

const {
  headline = 'Antes de reformar, a gente entende como você vive',
  subheadline = 'A sua reforma em Porto Alegre com prazo e orçamento garantidos em contrato',
} = Astro.props

const handleCTAClick = () => {
  document.getElementById('contato')?.scrollIntoView({ behavior: 'smooth' })
}
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <div class="absolute inset-0 z-0">
    <img
      src="/images/hero-bg.webp"
      alt="Reforma moderna e profissional"
      class="w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-navy-900/90 via-navy-800/80 to-navy-900/40"></div>
  </div>

  <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
    <h1 class="font-heading text-4xl sm:text-5xl lg:text-7xl font-bold text-white mb-6 leading-tight max-w-5xl mx-auto animate-fade-in-up">
      {headline}
    </h1>

    <p class="font-body text-lg sm:text-xl lg:text-2xl text-navy-100 mb-10 max-w-3xl mx-auto animate-fade-in-up delay-100">
      {subheadline}
    </p>

    <div class="animate-fade-in-up delay-200">
      <a
        href="#contato"
        class="inline-block bg-gradient-to-r from-gold to-gold-600 hover:from-gold-400 hover:to-gold-500 transition-all duration-300 text-white font-body font-bold text-lg px-10 py-5 rounded-full shadow-xl hover:shadow-2xl transform hover:-translate-y-1 hover:scale-105"
      >
        Falar com um Especialista Agora
      </a>
    </div>
  </div>

  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10 animate-bounce">
    <a href="#razoes" class="block text-white/50 hover:text-white transition-colors p-2">
      <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
      </svg>
    </a>
  </div>
</section>

<script>
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      e.preventDefault()
      const targetId = anchor.getAttribute('href')?.substring(1)
      if (targetId) {
        const target = document.getElementById(targetId)
        target?.scrollIntoView({ behavior: 'smooth' })
      }
    })
  })
</script>
