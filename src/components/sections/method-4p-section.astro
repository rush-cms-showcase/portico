---
import { methods } from '@/lib/data/methods'

interface Props {
	title?: string
}

const { title = 'Método Pórtico 4P™' } = Astro.props
---

<section class="relative py-32 sm:py-40 lg:py-48 bg-navy-900 text-white overflow-hidden">
	<div class="absolute inset-0 opacity-30">
		<div class="absolute top-0 left-0 w-96 h-96 bg-gold-600/10 rounded-full blur-3xl"></div>
		<div class="absolute bottom-0 right-0 w-96 h-96 bg-gold-600/10 rounded-full blur-3xl">
		</div>
	</div>

	<div class="container relative mx-auto px-4 sm:px-6 lg:px-8">
		<div class="max-w-7xl mx-auto">
			<div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start mb-20">
				<div class="lg:col-span-5">
					<div class="sticky top-8">
				<h2 class="font-heading text-5xl sm:text-6xl lg:text-7xl font-bold text-white mb-6">
							{title}
						</h2>

						<p class="font-body text-xl text-navy-100 leading-relaxed mb-8">
							O único sistema de reforma que garante prazo, preço e qualidade{' '}
							<span class="text-gold-500">em contrato</span>.
						</p>

						<div class="space-y-3">
							<div class="flex items-center gap-3 text-navy-200">
								<div class="w-2 h-2 bg-gold-600 rounded-full"></div>
								<span class="font-body">Blindagem contratual completa</span>
							</div>
							<div class="flex items-center gap-3 text-navy-200">
								<div class="w-2 h-2 bg-gold-600 rounded-full"></div>
								<span class="font-body">Multa por atraso de entrega</span>
							</div>
							<div class="flex items-center gap-3 text-navy-200">
								<div class="w-2 h-2 bg-gold-600 rounded-full"></div>
								<span class="font-body">Orçamento travado sem adicionais</span>
							</div>
						</div>

						<div class="mt-10 pt-8 border-t border-navy-700">
							<p class="font-body text-sm text-navy-300 italic">
								Metodologia patenteada e exclusiva da Pórtico Reformas
							</p>
						</div>
					</div>
				</div>

				<div class="lg:col-span-7">
					<div class="space-y-8">
						{
							methods.map((method) => (
								<div
									class="group relative"
								>
									<div class="relative bg-linear-to-br from-navy-800/50 to-navy-900/30 border-l-2 border-gold-600 p-8 lg:p-10 backdrop-blur-sm hover:border-gold-500 transition-all duration-500">
										<div class="absolute -left-px top-0 w-0.5 h-0 bg-gold-400 group-hover:h-full transition-all duration-700 ease-out" />

										<div class="flex items-start gap-6">
											<div class="shrink-0">
												<div class="relative w-16 h-16">
													<div class="absolute inset-0 bg-gold-600/20 transform rotate-45" />
													<div class="absolute inset-0 flex items-center justify-center">
														<span class="font-heading text-2xl font-black text-gold-500 relative z-10">
															{method.letter}
														</span>
													</div>
												</div>
											</div>

											<div class="flex-1 min-w-0">
												<h3 class="font-heading text-2xl lg:text-3xl font-bold text-white mb-2 group-hover:text-gold-500 transition-colors">
													{method.title}
												</h3>

												<p class="font-body text-sm text-gold-500 font-semibold mb-4 uppercase tracking-wide">
													{method.subtitle}
												</p>

												<p class="font-body text-base text-navy-100 leading-relaxed mb-6">
													{method.description}
												</p>

												<div class="flex flex-wrap gap-2">
													{method.features.map((feature) => (
														<span class="inline-flex items-center gap-1.5 bg-navy-800/50 border border-navy-700 px-3 py-1 rounded-sm text-xs text-navy-200 font-medium">
															<iconify-icon icon="mdi:check" class="w-3 h-3 text-gold-600" />
															{feature}
														</span>
													))}
												</div>
											</div>
										</div>
									</div>
								</div>
							))
						}
					</div>
				</div>
			</div>

			<div class="relative">
				<div class="absolute inset-0 bg-linear-to-r from-gold-600/20 via-gold-600/5 to-transparent">
				</div>
				<div class="relative max-w-4xl mx-auto text-center py-12 px-8">
					<div class="inline-block mb-6">
						<div class="flex items-center gap-4">
							<div class="h-px w-16 bg-gold-600"></div>
							<iconify-icon icon="mdi:seal-variant" class="text-gold-600 text-3xl"
							></iconify-icon>
							<div class="h-px w-16 bg-gold-600"></div>
						</div>
					</div>

					<p class="font-heading text-3xl lg:text-4xl text-white font-light italic leading-relaxed">
						"Não fazemos reforma.<br />
						Fazemos <span class="font-bold not-italic text-gold-500"
							>transformação inteligente</span
						> de espaços."
					</p>
				</div>
			</div>
		</div>
	</div>
</section>
