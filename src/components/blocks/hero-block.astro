---
interface Props {
  data: {
    badge?: string;
    headline: string;
    subheadline: string;
    cta_text: string;
    cta_link: string;
    background_image?: string;
  };
}

const { data } = Astro.props;
const bgImage = data.background_image || "/images/hero-bg.webp";
---

<section class="relative min-h-svh flex items-center overflow-hidden">
  <div class="absolute inset-0">
    <img src={bgImage} alt="" class="w-full h-full object-cover" fetchpriority="high" />
    <div class="absolute inset-0 bg-navy-900/80"></div>
  </div>
  <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8 py-32 lg:py-0">
    <div class="flex flex-col justify-center items-center text-center py-10 lg:py-32 max-w-4xl mx-auto">
      {data.badge && (
        <div class="inline-flex items-center gap-3 mb-6">
          <div class="w-2 h-2 bg-gold-600 rounded-full"></div>
          <span class="font-body text-sm text-gold-500 font-semibold tracking-widest uppercase">{data.badge}</span>
        </div>
      )}
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-8 leading-tight">
        {data.headline}
      </h1>
      <p class="font-body text-lg sm:text-xl text-navy-100 mb-12 max-w-2xl leading-relaxed">
        {data.subheadline}
      </p>
      <a
        href={data.cta_link}
        class="inline-flex items-center justify-center gap-2 rounded-full bg-linear-to-r from-gold-600 to-gold-700 px-8 py-4 font-heading font-bold text-base text-white shadow-2xl shadow-gold-600/30 hover:shadow-gold-600/50 transition-all hover:-translate-y-1"
      >
        {data.cta_text}
        <iconify-icon icon="mdi:arrow-right" class="text-lg"></iconify-icon>
      </a>
    </div>
  </div>
</section>
