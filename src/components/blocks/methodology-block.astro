---
import SectionContainer from '../sections/container.astro';
import SectionHeader from '../sections/section-header.astro';

interface Props {
  data: {
    section_badge?: string;
    section_title: string;
    items: {
      step: string;
      title: string;
      description: string;
    }[];
  };
}

const { data } = Astro.props;
---

<section class="bg-stone-50 py-24 sm:py-32">
  <SectionContainer>
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
        <div class="lg:col-span-5 min-w-0">
          <div class="sticky top-32">
            <SectionHeader badge={data.section_badge || ""} title={data.section_title} />
          </div>
        </div>

        <div class="lg:col-span-7 min-w-0">
          <div class="space-y-8">
            {data.items.map((item) => (
              <div class="group relative">
                <div class="relative bg-white border border-stone-200 border-l-2 border-l-gold-600 p-8 lg:p-10 rounded-r-2xl shadow-sm hover:shadow-xl transition-all duration-500">
                  <div class="absolute -left-0.5 top-0 w-1 h-0 bg-gold-500 group-hover:h-full transition-all duration-700 ease-out" />
                  
                  <div class="flex items-start gap-6">
                    <div class="shrink-0">
                      <div class="relative w-16 h-16">
                        <div class="absolute inset-0 bg-gold-600/10 transform rotate-45 rounded-lg" />
                        <div class="absolute inset-0 flex items-center justify-center">
                          <span class="font-heading text-2xl font-black text-gold-600 relative z-10">
                            {item.step}
                          </span>
                        </div>
                      </div>
                    </div>

                    <div class="flex-1 min-w-0">
                      <h3 class="font-heading text-2xl font-bold text-navy-900 mb-3 group-hover:text-gold-600 transition-colors">
                        {item.title}
                      </h3>
                      <p class="font-body text-charcoal/70 leading-relaxed">
                        {item.description}
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </SectionContainer>
</section>
