---
import HeroBlock from './hero-block.astro';
import PainPointsBlock from './pain-points-block.astro';
import ServicesBlock from './services-block.astro';
import MethodologyBlock from './methodology-block.astro';
import CtaBlock from './cta-block.astro';

interface Props {
  blocks: {
    _type: string;
    data: any;
  }[];
}

const { blocks } = Astro.props;
---

{blocks.map((block) => {
  switch (block._type) {
    case 'hero':
      return <HeroBlock data={block.data} />;
    case 'pain_points':
      return <PainPointsBlock data={block.data} />;
    case 'services':
      return <ServicesBlock data={block.data} />;
    case 'methodology':
      return <MethodologyBlock data={block.data} />;
    case 'cta':
      return <CtaBlock data={block.data} />;
    default:
      return null;
  }
})}
